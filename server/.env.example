# Email via SMTP (e.g. Gmail with an App Password, or any provider)
LEAD_EMAIL_TO=pparoos@gmail.com
LEAD_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
