---
/**
 * Lead — large standalone statement paragraph (the "problem" framing).
 * Text is passed via the default slot.
 */
interface Props {
  id?: string;
}

const { id = 'problem' } = Astro.props;
---

<section id={id}>
  <div class="lead-wrap landing-wrap reveal">
    <p class="lead-text"><slot /></p>
  </div>
</section>

<style>
  section {
    background: transparent;
    padding: clamp(5rem, 11vw, 9rem) 0;
  }

  .lead-text {
    font-family: var(--serif);
    font-size: clamp(1.45rem, 2.9vw, 2.1rem);
    font-weight: 400;
    line-height: 1.45;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0;
  }
</style>
</content>
