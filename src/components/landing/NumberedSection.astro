---
/**
 * NumberedSection — reusable numbered content block.
 * Two-column on desktop (number + label | body), single column on mobile.
 * Body content is passed via the default slot, so adding a new section is:
 *   <NumberedSection num="05" label="…" id="…"><p>…</p></NumberedSection>
 */
interface Props {
  num: string;
  label: string;
  id?: string;
}

const { num, label, id } = Astro.props;
---

<section id={id} class="content">
  <div class="section-grid landing-wrap reveal">
    <div class="section-head">
      <span class="section-num">{num}</span>
      <h2 class="section-label">{label}</h2>
    </div>
    <div class="section-body">
      <slot />
    </div>
  </div>
</section>

<style>
  section.content {
    background: transparent;
    padding: 0;
  }

  .section-grid {
    display: grid;
    grid-template-columns: var(--col-label) 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
    border-top: 1px solid var(--rule);
    padding: clamp(3rem, 6vw, 5rem) 0;
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .section-num {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1;
    color: var(--ink-faint);
  }

  .section-label {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--ink);
    margin: 0;
  }

  .section-body :global(p) {
    font-size: 1.15rem;
    line-height: 1.78;
    color: var(--ink-soft);
    margin: 0 0 1.1rem;
    font-weight: 400;
  }

  .section-body :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 720px) {
    .section-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .section-head {
      flex-direction: row;
      align-items: baseline;
      gap: 0.9rem;
    }

    .section-num {
      font-size: 1.6rem;
    }

    .section-label {
      font-size: 1.1rem;
    }

    .section-body :global(p) {
      font-size: 1.05rem;
    }
  }
</style>
</content>
