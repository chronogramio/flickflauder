---
/**
 * ChatInline — minimal inset console.
 * Suggestion chips to start, right-aligned question bubbles vs left-aligned
 * answer prose, markdown rendering, typewriter + blinking cursor, persisted
 * conversation with a clear button.
 * Backend URL from PUBLIC_CHAT_API_URL (build-time), default local dev server.
 */
const apiBase = import.meta.env.PUBLIC_CHAT_API_URL || 'http://localhost:8787';
const apiUrl = `${apiBase.replace(/\/$/, '')}/chat`;
---

<div id="ci" data-api={apiUrl}>
  <div class="term">
    <div id="ci-log" class="term-log" aria-live="polite"></div>

    <div id="ci-suggest" class="term-suggest">
      <button type="button" data-q="Hallo">Hallo</button>
      <button type="button" data-q="Erzähle mir mehr">Erzähle mir mehr</button>
      <button type="button" data-q="Kann ich ein Gespräch vereinbaren?">Kann ich ein Gespräch vereinbaren?</button>
    </div>

    <form id="ci-form" class="term-form">
      <span class="term-prompt" aria-hidden="true">&gt;</span>
      <span class="term-field">
        <span class="term-caret" aria-hidden="true"></span>
        <textarea id="ci-input" rows="1" placeholder="Frage eingeben …" autocomplete="off"></textarea>
      </span>
    </form>
  </div>

  <button id="ci-clear" class="term-clear" type="button" hidden>Gespräch löschen</button>
</div>

<style is:global>
  #ci { display: flex; flex-direction: column; }

  .term {
    --fg: #1c1a17;
    --dim: #9a948b;
    --mono: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, 'Liberation Mono', monospace;
    display: flex;
    flex-direction: column;
    height: 62vh;
    min-height: 360px;
    padding: 1.4rem 1.6rem;
    background: #fdfdfb;
    border-radius: 10px;
    box-shadow: inset 0 2px 6px rgba(28, 26, 23, 0.09), inset 0 14px 34px rgba(28, 26, 23, 0.045);
    font-family: var(--mono);
    overflow-y: auto;
    cursor: text;
  }

  /* Interactive children keep their own cursor (panel-wide cursor: text aside) */
  .term button, .term a, .term-clear { cursor: pointer; }

  .term-log {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--fg);
  }

  .term-line { white-space: pre-wrap; word-wrap: break-word; }

  /* Question — left-aligned tinted bubble (same side as you type) */
  .term-line.user {
    align-self: flex-start;
    max-width: 85%;
    color: var(--fg);
    background: rgba(28, 26, 23, 0.08);
    border-radius: 12px 12px 12px 4px;
    padding: 0.5rem 0.75rem;
    margin-top: 0.9rem;
  }
  .term-line.user:first-child { margin-top: 0; }

  /* Answer — left-aligned open prose */
  .term-line.agent {
    align-self: flex-start;
    max-width: 100%;
    color: var(--fg);
    margin-top: 0.15rem;
  }
  .term-line.agent.streaming::after {
    content: '▍';
    margin-left: 1px;
    color: var(--fg);
    animation: ci-blink 1.05s steps(2, jump-none) infinite;
  }
  @keyframes ci-blink { 0%, 49% { opacity: 1; } 50%, 100% { opacity: 0; } }

  /* Rendered markdown */
  .term-line.md { white-space: normal; }
  .term-line.md > :first-child { margin-top: 0; }
  .term-line.md > :last-child { margin-bottom: 0; }
  .term-line.md p { margin: 0 0 0.6em; }
  .term-line.md ul, .term-line.md ol { margin: 0.3em 0 0.6em; padding-left: 1.3em; }
  .term-line.md li { margin: 0.15em 0; }
  .term-line.md strong { font-weight: 600; }
  .term-line.md em { font-style: italic; }
  .term-line.md code {
    font-size: 0.92em;
    background: rgba(28, 26, 23, 0.06);
    padding: 0.05em 0.3em;
    border-radius: 3px;
  }
  .term-line.md a { color: var(--fg); text-decoration: underline; text-underline-offset: 2px; }

  /* Waiting dots */
  .term-line.typing { align-self: flex-start; display: flex; gap: 5px; align-items: center; margin-top: 0.15rem; }
  .term-line.typing span {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--dim);
    animation: ci-bounce 1.2s infinite ease-in-out;
  }
  .term-line.typing span:nth-child(2) { animation-delay: 0.15s; }
  .term-line.typing span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes ci-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-4px); opacity: 1; }
  }

  /* Suggestion chips */
  .term-suggest { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 0.2rem; }
  .term-suggest[hidden] { display: none; }
  .term-suggest button {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--dim);
    background: transparent;
    border: 1px solid rgba(28, 26, 23, 0.18);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .term-suggest button:hover { color: var(--fg); border-color: rgba(28, 26, 23, 0.4); }

  /* Prompt line */
  .term-form {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
    margin-top: 0.9rem;
    font-size: 0.92rem;
  }
  .term-prompt { color: var(--dim); }
  .term-field { position: relative; flex: 1; }
  .term-caret {
    position: absolute;
    left: 0;
    top: 0.2em;
    width: 1.5px;
    height: 1.05em;
    background: var(--fg);
    animation: ci-blink 1.05s steps(2, jump-none) infinite;
  }
  .term-form.editing .term-caret { display: none; }
  #ci-input {
    display: block;
    width: 100%;
    border: none;
    background: transparent;
    resize: none;
    font-family: var(--mono);
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--fg);
    caret-color: var(--fg);
    padding: 0;
    max-height: 120px;
  }
  #ci-input::placeholder { color: rgba(28, 26, 23, 0.4); }
  #ci-input:focus { outline: none; }

  /* Clear button */
  .term-clear {
    align-self: flex-end;
    margin-top: 0.9rem;
    background: none;
    border: none;
    color: var(--dim);
    font-family: var(--mono);
    font-size: 0.78rem;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .term-clear[hidden] { display: none; }
  .term-clear:hover { color: var(--fg); }

  @media (max-width: 480px) {
    .term {
      height: 70vh;
      height: 70svh;
      padding: 1.1rem 1.15rem;
    }
    .term-line.user { max-width: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .term-line.agent.streaming::after, .term-line.typing span, .term-caret { animation: none; }
  }
</style>

<script>
  const root = document.getElementById('ci');
  if (root) {
    const apiUrl = root.dataset.api;
    const term = root.querySelector('.term');
    const log = document.getElementById('ci-log');
    const suggest = document.getElementById('ci-suggest');
    const form = document.getElementById('ci-form');
    const input = document.getElementById('ci-input');
    const clearBtn = document.getElementById('ci-clear');

    const STORE = 'ff-chat-v1';
    const history = [];
    let busy = false;

    let sessionId = sessionStorage.getItem('ff-sid');
    if (!sessionId) { sessionId = newSid(); sessionStorage.setItem('ff-sid', sessionId); }
    function newSid() {
      return (crypto.randomUUID && crypto.randomUUID()) || String(Date.now()) + Math.random().toString(16).slice(2);
    }

    const scroll = () => { term.scrollTop = term.scrollHeight; };

    // --- markdown (HTML-safe) ---------------------------------------------
    const escapeHtml = (s) =>
      s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    function renderInline(s) {
      s = s.replace(/`([^`]+)`/g, (_m, p) => `<code>${p}</code>`);
      s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
      s = s.replace(/__([^_]+)__/g, '<strong>$1</strong>');
      s = s.replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>');
      s = s.replace(/(^|[^_\w])_([^_\n]+)_/g, '$1<em>$2</em>');
      s = s.replace(/\[([^\]]+)\]\((https?:\/\/[^\s)]+|mailto:[^\s)]+)\)/g,
        '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
      return s;
    }
    function renderMarkdown(src) {
      const lines = escapeHtml(src.trim()).split('\n');
      let html = '', list = null, para = [];
      const flushPara = () => { if (para.length) { html += '<p>' + renderInline(para.join('<br>')) + '</p>'; para = []; } };
      const closeList = () => { if (list) { html += `</${list}>`; list = null; } };
      for (const line of lines) {
        const t = line.trim();
        if (t === '') { flushPara(); closeList(); continue; }
        const ul = t.match(/^[-*]\s+(.*)$/);
        const ol = t.match(/^\d+\.\s+(.*)$/);
        if (ul) { flushPara(); if (list !== 'ul') { closeList(); html += '<ul>'; list = 'ul'; } html += '<li>' + renderInline(ul[1]) + '</li>'; continue; }
        if (ol) { flushPara(); if (list !== 'ol') { closeList(); html += '<ol>'; list = 'ol'; } html += '<li>' + renderInline(ol[1]) + '</li>'; continue; }
        closeList(); para.push(line);
      }
      flushPara(); closeList();
      return html;
    }
    function renderInto(el, src) { el.innerHTML = renderMarkdown(src); el.classList.add('md'); }

    // --- DOM helpers ------------------------------------------------------
    function addMessage(role, text) {
      const el = document.createElement('div');
      el.className = `term-line ${role === 'user' ? 'user' : 'agent'}`;
      el.textContent = text;
      log.appendChild(el);
      scroll();
      return el;
    }
    function addTyping() {
      const el = document.createElement('div');
      el.className = 'term-line typing';
      el.innerHTML = '<span></span><span></span><span></span>';
      log.appendChild(el);
      scroll();
      return el;
    }
    function typeText(el, text, cps) {
      return new Promise((resolve) => {
        el.classList.add('streaming');
        let shown = 0, last = performance.now();
        const step = (now) => {
          const dt = (now - last) / 1000; last = now;
          shown = Math.min(text.length, shown + Math.max(1, Math.round(cps * dt)));
          el.textContent = text.slice(0, shown);
          scroll();
          if (shown >= text.length) { el.classList.remove('streaming'); resolve(); return; }
          requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      });
    }

    // --- persistence ------------------------------------------------------
    function save() { try { localStorage.setItem(STORE, JSON.stringify(history)); } catch (e) {} }
    function updateChrome() {
      const has = history.length > 0;
      suggest.hidden = has;
      clearBtn.hidden = !has;
    }
    function restore() {
      let saved = [];
      try { saved = JSON.parse(localStorage.getItem(STORE) || '[]'); } catch (e) {}
      for (const m of saved) {
        if (m.role === 'user') addMessage('user', m.content);
        else { renderInto(addMessage('agent', ''), m.content); }
        history.push(m);
      }
      updateChrome();
      scroll();
    }
    restore();

    clearBtn.addEventListener('click', () => {
      history.length = 0;
      try { localStorage.removeItem(STORE); } catch (e) {}
      log.innerHTML = '';
      sessionId = newSid();
      sessionStorage.setItem('ff-sid', sessionId);
      updateChrome();
      input.focus();
    });

    // --- input ------------------------------------------------------------
    input.addEventListener('focus', () => form.classList.add('editing'));
    input.addEventListener('blur', () => { if (!input.value) form.classList.remove('editing'); });
    input.addEventListener('input', () => {
      form.classList.add('editing');
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 120) + 'px';
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(input.value); }
    });
    suggest.addEventListener('click', (e) => {
      const btn = e.target.closest('button[data-q]');
      if (btn) send(btn.dataset.q);
    });

    // Clicking anywhere on the panel starts typing — unless the user clicked an
    // interactive element (chip, link, clear) or is selecting text to copy.
    term.addEventListener('mouseup', (e) => {
      if (busy) return;
      if (e.target.closest('button, a, textarea')) return;
      const selection = window.getSelection();
      if (selection && selection.toString()) return;
      input.focus();
    });

    async function send(raw) {
      const text = (raw || '').trim();
      if (!text || busy) return;

      busy = true;
      input.value = '';
      input.style.height = 'auto';
      form.classList.remove('editing');
      form.style.display = 'none';

      addMessage('user', text);
      history.push({ role: 'user', content: text });
      save();
      updateChrome();

      const typingEl = addTyping();
      let botEl = null, answer = '', shown = 0, streamDone = false;

      const ensureBubble = () => {
        if (!botEl) {
          if (typingEl.isConnected) typingEl.remove();
          botEl = addMessage('agent', '');
          botEl.classList.add('streaming');
        }
      };

      let resolveDone;
      const finished = new Promise((r) => (resolveDone = r));
      let last = performance.now();
      const reveal = (now) => {
        const dt = (now - last) / 1000; last = now;
        if (botEl) {
          const remaining = answer.length - shown;
          if (remaining > 0) {
            const cps = Math.min(220, 50 + remaining * 1.5);
            shown = Math.min(answer.length, shown + Math.max(1, Math.round(cps * dt)));
            botEl.textContent = answer.slice(0, shown);
            scroll();
          }
        }
        if (streamDone && shown >= answer.length) { resolveDone(); return; }
        requestAnimationFrame(reveal);
      };
      requestAnimationFrame(reveal);

      try {
        const resp = await fetch(apiUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history, sessionId }),
        });
        if (!resp.ok || !resp.body) throw new Error(`HTTP ${resp.status}`);
        const reader = resp.body.getReader();
        const decoder = new TextDecoder();
        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          answer += decoder.decode(value, { stream: true });
          ensureBubble();
        }
      } catch (err) {
        answer = answer || 'Verbindung nicht verfügbar. Schreiben Sie Pascal direkt: pascal@flickflauder.com';
        ensureBubble();
      } finally {
        streamDone = true;
        await finished;
        if (typingEl.isConnected) typingEl.remove();
        if (botEl) {
          botEl.classList.remove('streaming');
          if (answer.trim()) renderInto(botEl, answer);
        }
        if (answer.trim()) { history.push({ role: 'assistant', content: answer }); save(); }
        busy = false;
        form.style.display = '';
        input.focus();
        scroll();
      }
    }
  }
</script>
