---
/**
 * BlogCard Component
 * Card for displaying blog posts
 */

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  lang: 'de' | 'en';
  class?: string;
}

const { title, description, pubDate, tags, slug, lang, class: className = '' } = Astro.props;

// Remove language prefix from slug if present
const cleanSlug = slug.replace(/^(de|en)\//, '');
const blogUrl = lang === 'de' ? `/blog/${cleanSlug}` : `/en/blog/${cleanSlug}`;
const formattedDate = pubDate.toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class={`blog-card ${className}`}>
  <div class="blog-content">
    <div class="blog-meta">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    </div>
    <h3>
      <a href={blogUrl}>{title}</a>
    </h3>
    <p>{description}</p>
    <div class="tags">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
    <a href={blogUrl} class="read-more">
      {lang === 'de' ? 'Weiterlesen' : 'Read More'} →
    </a>
  </div>
</article>

<style>
  .blog-card {
    background: white;
    padding: 2.5rem;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    transition: transform var(--transition-normal),
      box-shadow var(--transition-normal);
    border: 2px solid #f0f0f0;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: var(--lavender);
  }

  .blog-meta {
    margin-bottom: 1rem;
  }

  .blog-meta time {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .blog-card h3 {
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .blog-card h3 a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition-normal);
  }

  .blog-card h3 a:hover {
    color: var(--lavender);
  }

  .blog-card p {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: rgba(168, 230, 207, 0.1);
    border: 1px solid var(--mint);
    border-radius: 15px;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .read-more {
    display: inline-block;
    color: var(--lavender);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-normal);
  }

  .read-more:hover {
    color: var(--peach);
  }
</style>
