---
/**
 * ProjectCard Component
 * Card for displaying portfolio projects
 */

interface Props {
  title: string;
  description: string;
  thumbnail: string;
  technologies: string[];
  slug: string;
  lang: 'de' | 'en';
  class?: string;
}

const { title, description, thumbnail, technologies, slug, lang, class: className = '' } = Astro.props;

// Remove language prefix from slug if present
const cleanSlug = slug.replace(/^(de|en)\//, '');
const projectUrl = lang === 'de' ? `/portfolio/${cleanSlug}` : `/en/portfolio/${cleanSlug}`;
---

<article class={`project-card ${className}`}>
  <div class="project-thumbnail">
    <img
      src={thumbnail}
      alt={title}
      onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 400 300%27%3E%3Crect width=%27400%27 height=%27300%27 fill=%27%23b8a4d4%27/%3E%3Ctext x=%2750%25%27 y=%2750%25%27 dominant-baseline=%27middle%27 text-anchor=%27middle%27 font-size=%2760%27 fill=%27white%27%3EProject%3C/text%3E%3C/svg%3E'"
    />
  </div>
  <div class="project-content">
    <h3>{title}</h3>
    <p>{description}</p>
    <div class="technologies">
      {technologies.map((tech) => <span class="tech-tag">{tech}</span>)}
    </div>
    <a href={projectUrl} class="project-link">
      {lang === 'de' ? 'Projekt ansehen' : 'View Project'} →
    </a>
  </div>
</article>

<style>
  .project-card {
    background: white;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    transition: transform var(--transition-normal),
      box-shadow var(--transition-normal);
    border: 2px solid #f0f0f0;
  }

  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: var(--lavender);
  }

  .project-thumbnail {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .project-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .project-card:hover .project-thumbnail img {
    transform: scale(1.05);
  }

  .project-content {
    padding: 2rem;
  }

  .project-content h3 {
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 1rem;
    color: var(--text-secondary);
  }

  .project-content p {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .technologies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tech-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: rgba(184, 164, 212, 0.1);
    border: 1px solid var(--lavender);
    border-radius: 15px;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .project-link {
    display: inline-block;
    color: var(--lavender);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-normal);
  }

  .project-link:hover {
    color: var(--peach);
  }
</style>
